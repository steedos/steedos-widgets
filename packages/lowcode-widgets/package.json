{
  "name": "@steedos/lowcode-widgets",
  "version": "0.0.3",
  "description": "@steedos/lowcode-widgets",
  "main": "lib/index.js",
  "module": "es/index.js",
  "typings": "types/index.d.ts",
  "files": [
    "build",
    "dist",
    "lib",
    "es",
    "types"
  ],
  "scripts": {
    "start": "build-scripts start",
    "build": "NODE_OPTIONS=--max_old_space_size=4096 && build-scripts build",
    "lowcode:dev": "build-scripts start --config ./build.lowcode.js",
    "lowcode:build": "build-scripts build --config ./build.lowcode.js",
    "f2elint-scan": "f2elint scan",
    "f2elint-fix": "f2elint fix",
    "release": "yarn run build && yarn run lowcode:build && yarn publish"
  },
  "directories": {
    "test": "test"
  },
  "keywords": [
    "Fusion"
  ],
  "author": "fusion-team",
  "license": "MIT",
  "husky": {
    "hooks": {
      "pre-commit": "f2elint commit-file-scan",
      "commit-msg": "f2elint commit-msg-scan"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,vue}": "f2elint exec eslint",
    "**/*.{css,scss,less,acss}": "f2elint exec stylelint"
  },
  "peerDependencies": {
    "moment": "latest",
    "react": "^16.x",
    "react-dom": "^16.x"
  },
  "devDependencies": {
    "@alib/build-scripts": "^0.1.3",
    "@alifd/build-plugin-lowcode": "^0.2.0",
    "@alifd/theme-2": "^0.4.0",
    "@storybook/addon-actions": "^6.3.1",
    "@storybook/addon-docs": "^6.3.4",
    "@storybook/addon-essentials": "^6.3.0",
    "@storybook/addon-storysource": "^6.3.1",
    "@storybook/react": "^6.3.5",
    "@storybook/source-loader": "^6.3.1",
    "@types/react": "^16.14.24",
    "@types/react-dom": "^16.9.4",
    "build-plugin-component-multiple": "^1.0.0-beta.5",
    "build-plugin-fusion": "^0.1.0",
    "f2elint": "^1.2.0"
  },
  "dependencies": {
    "@alifd/next": "^1.25.27",
    "@ant-design/icons": "^4.6.2",
    "@ant-design/pro-card": "^1.18.42",
    "@ant-design/pro-field": "^1.33.1",
    "@ant-design/pro-form": "^1.59.3",
    "@ant-design/pro-layout": "^6.32.11",
    "@ant-design/pro-provider": "^1.6.1",
    "@ant-design/pro-skeleton": "^1.0.5",
    "@ant-design/pro-table": "^2.68.3",
    "@ant-design/pro-utils": "^1.37.2",
    "@chakra-ui/accordion": "^1.2.0",
    "@chakra-ui/icons": "^1.1.7",
    "@chakra-ui/layout": "^1.4.0",
    "@chakra-ui/system": "^1.6.0",
    "@emotion/react": "^11.8.2",
    "@steedos-builder/react": "^0.2.16",
    "@steedos-builder/sdk": "^0.2.16",
    "@steedos-ui/builder-ag-grid": "1.1.27",
    "@steedos-ui/builder-lightning": "1.1.27",
    "@steedos-ui/builder-object": "^1.1.27",
    "@steedos-ui/builder-page": "1.1.27",
    "@steedos-widgets/design-system": "^0.2.5",
    "antd": "^4.19.5",
    "prop-types": "^15.5.8",
    "react": "^16.x",
    "react-dom": "^16.x"
  },
  "acceptDependencies": {
    "webpack": "^4.46.x"
  },
  "publishConfig": {
    "access": "public"
  },
  "componentConfig": {
    "isComponentLibrary": true,
    "materialSchema": "https://unpkg.com/@steedos/lowcode-widgets@0.0.3/build/lowcode/assets-prod.json"
  }
}