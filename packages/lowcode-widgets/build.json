{
  "library": "lowcode-widgets",
  "libraryTarget": "umd",
  "sourceMap": true,
  "alias": {
    "@": "./src/components"
  },
  "externals": {
    "react": "var window.React",
    "react-dom": "var window.ReactDOM",
    "prop-types": "var window.PropTypes",
    "@alifd/next": "var window.Next",
    "@alilc/lowcode-engine": "var window.AliLowCodeEngine",
    "@alilc/lowcode-editor-core": "var window.AliLowCodeEngine.common.editorCabin",
    "@alilc/lowcode-editor-skeleton": "var window.AliLowCodeEngine.common.skeletonCabin",
    "@alilc/lowcode-designer": "var window.AliLowCodeEngine.common.designerCabin",
    "@alilc/lowcode-engine-ext": "var window.AliLowCodeEngineExt",
    "@steedos-builder/react": "var window.BuilderReact",
    "@steedos-builder/sdk": "var window.BuilderReact",
    "@steedos-widgets/design-system": "var window.antd",
    "antd": "var window.DesignSystem",
    "moment": "var window.moment",
    "lodash": "var window._"
  },
  "plugins": [
    ["build-plugin-component-multiple", {
      "themePackage": "@alifd/theme-2"
    }],
    "./build.plugin.js"
  ]
}
