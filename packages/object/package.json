    "@steedos-ui/builder-ag-grid": "^1.1.29",
    "@steedos-ui/builder-lightning": "^1.1.29",
    "@steedos-ui/builder-object": "^1.1.29",
    "@steedos-ui/builder-page": "^1.1.29",
    "antd": "^4.19.2",
    "lodash-es": "^4.17.10",
    "next": "^12.1.0",
    "polished": "^4.2.1",
